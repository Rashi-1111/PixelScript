<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Sanskriti</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="container">
        <!-- Logo at the center -->
        <img src="logo.png" alt="Sanskriti Logo" class="logo">

        <!-- Login credentials section -->
        <div class="login-section">
            <h2>LOGIN CREDENTIALS</h2>
            <div class="input-box">
                <label for="username">USERNAME:</label>
                <input type="text" id="username" placeholder="SHEBINARY">
            </div>
            <div class="input-box">
                <label for="password">PASSWORD:</label>
                <input type="password" id="password" placeholder="SHEBINARY@6">
            </div>
            <button type="button" onclick="validate()">Login</button>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
